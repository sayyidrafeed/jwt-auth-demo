# Database Connection String
# Use Neon URL for production, or local postgres URL for Docker compose.
DATABASE_URL=postgresql://postgres:password@localhost:5433/jwtauth

# JWT Security
# Generate a secret with: openssl rand -base64 32
JWT_SECRET=supersecretjwtkeythatmustbe32byteslongormore!

# JWT Expiry Times
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Feature Flag: Enable Token Blacklisting (Revocation checking on every request)
# Set to 'true' to query revoked_tokens table on each JWT verification
ENABLE_TOKEN_BLACKLIST=false
